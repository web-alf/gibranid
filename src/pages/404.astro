---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Halaman Tidak Ditemukan · gibran.id">
  <div style="min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 60px 32px;">
    <div style="font-family: var(--font-serif,'Fraunces',serif); font-size: clamp(80px,20vw,200px); font-weight: 300; line-height: 1; letter-spacing: -0.05em; color: var(--color-line);">404</div>
    <h1 style="font-family: var(--font-serif,'Fraunces',serif); font-weight: 300; font-size: clamp(28px,4vw,48px); letter-spacing: -0.03em; margin-bottom: 16px;">Halaman tidak ditemukan.</h1>
    <p style="color: var(--color-muted); font-size: 18px; margin-bottom: 40px;">Halaman yang Anda cari tidak tersedia atau telah dipindahkan.</p>
    <a href="/" class="btn-primary">Kembali ke Beranda →</a>
  </div>
</BaseLayout>
