---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  schemas?: Record<string, unknown>[];
}

const { title, description, schemas } = Astro.props;
---
<BaseLayout title={title} description={description} schemas={schemas}>
  <div style="padding-top: 80px;">
    <slot />
  </div>
</BaseLayout>
